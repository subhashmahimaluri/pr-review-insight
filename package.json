{
  "name": "pr-review-insight",
  "version": "0.1.0",
  "private": true,
  "description": "PR Review Insight — scan PRs for dead code, duplication, complexity, security, OWASP, a11y and code smells; post one premium PR comment and gate the merge on what the PR introduced.",
  "main": "dist/index.js",
  "repository": "https://github.com/subhashmahimaluri/pr-review-insight.git",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "npm run build -ws --if-present",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:mutation": "stryker run",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.30.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "^22.10.0",
    "@types/picomatch": "^4.0.0",
    "@vercel/ncc": "^0.38.3",
    "@vitest/coverage-v8": "^3.2.0",
    "eslint": "^9.30.0",
    "eslint-config-prettier": "^10.1.0",
    "fast-check": "^4.8.0",
    "prettier": "^3.5.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.40.0",
    "vitest": "^4.1.8"
  }
}
